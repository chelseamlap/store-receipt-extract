{
  "manifest_version": 3,
  "name": "store-receipt-extract",
  "version": "0.1.0",
  "description": "Extract itemized Target + Costco order history to CSV/JSON for personal spend analysis. Local-only.",
  "key": "",
  "permissions": ["storage", "downloads", "webRequest", "declarativeNetRequestWithHostAccess"],
  "host_permissions": [
    "https://www.target.com/*",
    "https://api.target.com/*",
    "https://www.costco.com/*",
    "https://ecom-api.costco.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "store-receipt-extract",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
